<?xml version="1.0" encoding="UTF-8"?>

<VBox spacing="15" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.TimetableController"
      styleClass="root">

    <Label text="Upload Timetable" styleClass="title"/>

    <TextArea fx:id="timetableArea" promptText="Enter busy slots (e.g. Mon 10-11)" prefHeight="150"/>

    <Button text="Upload" onAction="#handleUpload" styleClass="button"/>

    <Label fx:id="statusLabel"/>

</VBox>